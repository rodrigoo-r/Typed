Use IO;
Use Strings;

Procedure Main
Begin
    Call
        Print_Line
    With
        "Enter your name \xF0\x9F\x98\x80:"
    End_Call;

    Declare
        Name as String
    With
        Call
            Read_Line
        End_Call
    ;

    Call
        Print_Line
    With
        "Hello, $S",
        Call
            String_Access
        With
            "Hello, world",
            1
        End_Call
    End_Call;

End_Procedure