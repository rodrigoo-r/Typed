# Test Script
# This is a comment

#Use Regex; # Import the Regex library
Use IO; # Import the IO library for printing
# Available libraries:
# - Regex
# - IO
# - Math
# - String
# - List
# - Dictionary
# - FileSystem

Procedure Main
With Arguments
    # No arguments for this procedure
    # Example:
    # Arg1 as String
    # Arg2 as Integer
Begin
    Call
        Println
    With
        "$S! This is my int: $I",
        "Hello, world",
        25
    ;

    Call
        Println
    With
        "And this is my float: $F",
        25.19
    ;

    Call
        Println
    With
        "And my boolean: $B. And my other boolean: $B",
        True,
        False
    ;
End_Procedure