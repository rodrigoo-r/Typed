# Test Script
# This is a comment

#Use Regex; # Import the Regex library
Use IO; # Import the IO library for printing
# Available libraries:
# - Regex
# - IO
# - Math
# - String
# - List
# - Dictionary
# - FileSystem

Procedure Main
With Arguments
    # No arguments for this procedure
    # Example:
    # Arg1 as String
    # Arg2 as Integer
Begin
    Call
        Print_Line
    With
        "Enter your name: "
    End_Call;

    Declare
        Name as String
    With
        Call
            Read_Line
        End_Call;

    Call
        Print_Line
    With
        "Hello, $S!",
            Name
    End_Call;

    Call
        Print_Line
    With
        "$S! This is my int: $I",
        "Hello, world",
        25
    End_Call;

    Call
        Print_Line
    With
        "And this is my float: $F",
        25.19
    End_Call;

    Call
        Print_Line
    With
        "And my boolean: $B. And my other boolean: $B",
        True,
        False
    End_Call;

    Declare
        Result as Integer
    With
        25;

    Call
        Print_Line
    With
        "Result before Add: $I",
        Result
    End_Call;

    Add
        5
    To
        Result
    ;

    Call
        Print_Line
    With
        "Result after Add: $I",
        Result;

    Multiply
        Result
    By
        25214500;

    Call
        Print_Line
    With
        "Result after Mul: $I",
        Result
    End_Call;

    Divide
        Result
    By
        25214500; # Should be 30

    Call
        Print_Line
    With
        "Result after Div: $I",
        Result
    End_Call;

    If
        9 >= 7 Or
        1 <= 2 Or
        2 < 5 Or
        5 > 2 And
        1 < 2 Or
        1 == 1
    Then
    Begin
        Call
            Print_Line
        With
            "Result after Div: $I",
            Result
        End_Call;
    End_If
End_Procedure