# Test Script
# This is a comment

Use IO; # Import the IO library for printing
Use Lists;
Use Dictionaries;
Use Strings;
Use Math;
Use File_System;
# Available libraries:
# - Regex_Engine
# - IO
# - Math
# - Strings
# - Lists
# - Dictionaries
# - File_System

Procedure Main
With Arguments
    # No arguments for this procedure
    # Example:
    # Arg1 as String
    # Arg2 as Integer
Begin
    Call
        Print_Line
    With
        "Enter your name: "
    End_Call;

    Declare
        Name as String
    With
        Call
            Read_Line
        End_Call;

    Call
        Print_Line
    With
        "Hello, $S!",
            Name
    End_Call;

    Call
        Print_Line
    With
        "$S! This is my int: $I",
        "Hello, world",
        25
    End_Call;

    Call
        Print_Line
    With
        "And this is my float: $F",
        25.19
    End_Call;

    Call
        Print_Line
    With
        "And my boolean: $B. And my other boolean: $B",
        True,
        False
    End_Call;

    Declare
        Result as Integer
    With
        25;

    Call
        Print_Line
    With
        "Result before Add: $I",
        Result
    End_Call;

    Add
        5
    To
        Result
    ;

    Call
        Print_Line
    With
        "Result after Add: $I",
        Result
    End_Call;

    Multiply
        Result
    By
        25214500;

    Call
        Print_Line
    With
        "Result after Mul: $I",
        Result
    End_Call;

    Divide
        Result
    By
        25214500; # Should be 30

    Call
        Print_Line
    With
        "Result after Div: $I",
        Result
    End_Call;

    If
        False
    Then
    Begin
        Declare
            Result as Integer
        With
            467;

        Call
            Print_Line
        With
            "Inner Result: $I",
            Result
        End_Call;
    Else_If 1 == 1 Then
    Begin
        Call
            Print_Line
        With
            "Elseif!"
        End_Call;
    Else
    Begin
        Call
            Print_Line
        With
            "No inner result"
        End_Call;
    End_If

    Call
        Print_Line
    With
        "Outer Result: $I",
        Result
    End_Call;

    For
        I as Integer
    In
        0
    To
        10
    Step
        1
    Do
    Begin
        Call
            Print_Line
        With
            "I: $I",
            I
        End_Call;
    End_For

    Declare
        I as Integer
    With
        0;

    While
        I < 10
    Do
    Begin
        Call
            Print_Line
        With
            "I in While: $I",
            I
        End_Call;

        Add 1 To I;
    End_While

    Declare My_List as List;
    Declare My_Dict as Dictionary;

    Call
        List_Add
    With
        My_List,
        "Hello",
        2.5,
        True
    End_Call;

    Call
        Print_Line
    With
        "My List: $L",
        My_List
    End_Call;

    Call
        List_Pop
    With
        My_List
    End_Call;

    Call
        Print_Line
    With
        "My List: $L. Access: $S",
        My_List,
        Call List_Access With My_List, 0 End_Call
    End_Call;

    Call
        Print_Line
    With
        "My Dict: $D",
        My_Dict
    End_Call;

    Call
        List_Set
    With
        My_List,
        0,
        "Goodbye"
    End_Call;

    Call
        Print_Line
    With
        "My List: $L",
        My_List
    End_Call;

    Call
        Dictionary_Set
    With
        My_Dict,
        "Hello",
        "World"
    End_Call;

    Call
        Print_Line
    With
        "My Dict: $D",
        My_Dict
    End_Call;

    Call
        Print_Line
    With
        "Hello: $S",
        Call
            Dictionary_Access
        With
            My_Dict, "Hello"
        End_Call
    End_Call;

    Call
        Print_Line
    With
        "First letter: $S",
        Call
            String_Access
        With
            Call
                Dictionary_Access
            With
                My_Dict, "Hello"
            End_Call,
            0
        End_Call
    End_Call;

    Declare
        S as String
    With
        "     Hello, World       ";

    Declare
        S as String
    With
        Call
            String_Trim
        With
            S
        End_Call;

    Call
        Print_Line
    With
        "Trimmed: '$S'",
        S
    End_Call;

    Call
        Print_Line
    With
        "Replace: $S",
        Call
            String_To_Upper
        With
            "Hell. I will see you in Hell."
        End_Call
    End_Call;

    Call
        Print_Line
    With
        "Fmt: $S",
        Call
            String_Format
        With
            "Hello, $S!",
            "World"
        End_Call
    End_Call;

    Call
        Print_Line
    With
        "Sine of 180: $F",
        Call
            Sine
        With
            180
        End_Call
    End_Call;

    Call
        Print_Line
    With
        "Cwd: $S",
        Call
            Process_Cwd
        End_Call
    End_Call;

End_Procedure